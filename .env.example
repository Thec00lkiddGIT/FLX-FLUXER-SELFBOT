# Your user account token (not a bot token). See README for how to obtain it.
FLUXER_TOKEN=

# Command prefix (default: !)
PREFIX=!

# Host only - Flx appends /v1 (not /api/v1)
FLUXER_API_URL=https://api.fluxer.app

# Optional API keys (required only for matching commands)
C99_WEATHER_KEY=
GLSERIES_TOKEN=
GLSERIES_BASE_URL=https://live.glseries.net/api/v1
API_NINJAS_KEY=
SERPAPI_KEY=
OSINT_INDUSTRIES_KEY=

# Poof.bg background removal (!poof) - https://docs.poof.bg
POOF_API_KEY=

# FLX Assistant (local Llama via Ollama — https://ollama.com)
# Install Ollama, then: ollama pull llama3.2
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
